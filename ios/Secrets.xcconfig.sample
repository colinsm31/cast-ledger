// Copy this file to `Secrets.xcconfig` (same folder) and fill in real values.
// `Secrets.xcconfig` is gitignored — real keys are never committed.
//
// Values come from the Supabase dashboard: Project Settings → API.
// The anon key is the public client key; RLS enforces access. It still lives
// here (build config) rather than in source so it isn't committed.
//
// SUPABASE_HOST is the host ONLY — no `https://`, no trailing slash, no path.
// The app adds the https:// scheme in Swift, so nothing slash-related has to
// survive the xcconfig → Info.plist round trip.

SUPABASE_HOST = YOUR-PROJECT-ref.supabase.co
SUPABASE_ANON_KEY = your-anon-public-key
